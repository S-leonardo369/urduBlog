# ─────────────────────────────────────────────────────────────
# Keystatic GitHub mode — required for the /keystatic admin to
# work on the deployed site (Vercel). Not needed for local dev
# in "local" mode, but required once you switch to "github" mode.
# ─────────────────────────────────────────────────────────────

# Your public Vercel URL — used to build the correct OAuth redirect_uri.
# Must match exactly what's in your GitHub OAuth App's callback URL field.
# No trailing slash. Leave blank for local dev (local mode is used there).
KEYSTATIC_URL=https://roshanai-blog.vercel.app

# Your GitHub repo (where Keystatic will commit content changes)
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=your-repo-name

# From your GitHub OAuth App (Settings > Developer settings > OAuth Apps)
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=

# Random secret used to sign Keystatic session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEYSTATIC_SECRET=

# The slug of your GitHub App (only needed if using GitHub App auth instead of OAuth App)
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
