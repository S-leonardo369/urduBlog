---
export const prerender = true;

import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = await getCollection('posts');
const posts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function estimateReadTime(body: string): string {
  const toUrduNum = (n: number) =>
    n.toString().replace(/\d/g, ch => '۰۱۲۳۴۵۶۷۸۹'[+ch]);
  const words = body.trim().split(/\s+/).length;
  const mins = Math.max(1, Math.round(words / 150));
  return `${toUrduNum(mins)} منٹ`;
}
---

<BaseLayout title="روشنائی — ایک ذاتی بلاگ" description="سوچوں کا گھر، الفاظ کا سفر">
  <header class="site-header">
    <div class="container">
      <h1 class="site-name">روشنائی</h1>
      <span class="site-name-en">Roshnai — a personal blog</span>
      <p class="site-tagline">سوچوں کا گھر، الفاظ کا سفر</p>
      <nav class="site-nav">
        <a href="/about">About</a>
        <a href="/archive">Archive</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    <div class="container">
      <div class="section-label">Latest Posts</div>
      <ul class="post-list">
        {posts.map((post, i) => (
          <PostCard
            slug={post.id.replace(/\.(md|mdoc)$/, '')}
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            readTime={estimateReadTime(post.body ?? '')}
            featured={i === 0}
            animationDelay={`${0.1 + i * 0.1}s`}
          />
        ))}
      </ul>
    </div>
  </main>

  <footer class="site-footer">
    <div class="footer-links">
      <a href="#" class="footer-link">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
        Twitter / X
      </a>
      <a href="#" class="footer-link">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        Instagram
      </a>
      <a href="/rss.xml" class="footer-link">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
        </svg>
        RSS Feed
      </a>
    </div>
    <p class="footer-copy">© ۲۰۲۵ روشنائی — جملہ حقوق محفوظ</p>
  </footer>
</BaseLayout>

<style>
  .site-header {
    padding: 56px 0 44px;
    border-bottom: 1px solid var(--rule);
    text-align: center;
    animation: fadeUp 0.7s ease both;
  }
  .site-name {
    font-family: var(--font-urdu);
    font-size: clamp(3.4rem, 9vw, 5.6rem);
    font-weight: 700;
    line-height: 1.5;
    color: var(--ink);
  }
  .site-name-en {
    font-family: var(--font-en);
    font-size: 0.88rem;
    font-style: italic;
    color: var(--ink-muted);
    letter-spacing: 0.14em;
    display: block;
    margin-top: 4px;
  }
  .site-tagline {
    font-family: var(--font-urdu);
    font-size: 1rem;
    line-height: 2.2;
    color: var(--ink-muted);
    margin-top: 16px;
  }
  .site-nav {
    display: flex;
    justify-content: center;
    gap: 36px;
    margin-top: 26px;
    font-family: var(--font-en);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .site-nav a { transition: color 0.2s; }
  .site-nav a:hover { color: var(--accent); }

  .section-label {
    font-family: var(--font-en);
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 56px 0 0;
    display: flex;
    align-items: center;
    gap: 14px;
    opacity: 0.7;
  }
  .section-label::before,
  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--rule);
  }

  .post-list { list-style: none; margin-top: 0; }

  .site-footer {
    margin-top: 80px;
    padding: 44px 0 60px;
    border-top: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
    animation: fadeUp 0.6s 0.5s ease both;
    opacity: 0;
    animation-fill-mode: forwards;
  }
  .footer-links {
    display: flex;
    gap: 32px;
    align-items: center;
  }
  .footer-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-en);
    font-size: 0.76rem;
    letter-spacing: 0.1em;
    color: var(--ink-muted);
    transition: color 0.2s;
  }
  .footer-link:hover { color: var(--accent); }
  .footer-link svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
    flex-shrink: 0;
  }
  .footer-copy {
    font-family: var(--font-en);
    font-size: 0.7rem;
    color: var(--ink-muted);
    letter-spacing: 0.06em;
    opacity: 0.5;
  }

  @media (max-width: 480px) {
    .site-header { padding: 44px 0 36px; }
    .site-nav { gap: 24px; }
    .footer-links { gap: 20px; flex-wrap: wrap; justify-content: center; }
  }
</style>